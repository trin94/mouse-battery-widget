{
    "$schema": "https://raw.githubusercontent.com/AvengeMedia/DankMaterialShell/refs/heads/master/quickshell/PLUGINS/plugin-schema.json",
    "id": "mouseBatteryWidget",
    "name": "Mouse Battery Widget",
    "description": "Shows wireless mouse battery level in the bar",
    "version": "1.0.0",
    "author": "Elias Mueller",
    "homepage": "https://github.com/trin94/mouse-battery-widget",
    "icon": "mouse",
    "type": "widget",
    "capabilities": ["dankbar-widget", "battery", "peripheral"],
    "component": "./src/qml/MouseBatteryWidget.qml",
    "settings": "./src/qml/MouseBatterySettings.qml",
    "requires_dms": ">=1.4.0",
    "permissions": ["settings_read", "settings_write", "process"]
}
